<?xml version="1.0" ?>
<robot name="kikobot" xmlns:xacro="http://ros.org/wiki/xacro">

<xacro:include filename="materials.xacro" />

<link name="world" />
<joint name="world_joint" type="fixed">
  <parent link="world" />
  <child link="base_link" />
  <origin xyz="0 0 0" rpy="0 0 0" />
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="0.003411847404905988 0.0003910038603105255 0.0316923242999685" rpy="0 0 0"/>
    <mass value="1.7062291432573238"/>
    <inertia ixx="0.002831" iyy="0.002886" izz="0.00316" ixy="-2e-06" iyz="6e-06" ixz="4.7e-05"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

