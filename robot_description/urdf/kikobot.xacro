<link name="end_effector_1">
  <inertial>
    <origin xyz="-0.026309276724266084 0.00021112832590368028 -1.6639945410457102e-06" rpy="0 0 0"/>
    <mass value="0.1883404088166293"/>
    <inertia ixx="5.8e-05" iyy="4.7e-05" izz="4.7e-05" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.104738 9.7e-05 -0.513295" rpy="0 0 0"/>
