graph TD

subgraph S1[STAGE 1 - Data Ingestion]
    JSON[Raw JSON Log Files raw_samples.json]
    PARSER[TorqueDataLoader.parse_log]
    JSON --> PARSER
end

PARSER --> TSEC["Timestamps $$\quad t \quad$$ in seconds"]
PARSER --> QTICK["Position Ticks 0 to 4096 per rev"]
PARSER --> LREG["Load Register 
$$
\pm 1000
$$
"]
PARSER --> VREG["Voltage Register 6V to 12.6V"]
PARSER --> JCFG[Joint Mapping Config]

subgraph S2[STAGE 2 - Preprocessing and Calibration]
    TICK2R["Ticks to Radians 
$$
q = d \cdot (tick - c) \cdot \frac{2\pi}{4096} + \theta_{off}
$$
"]
    TNORM["Time Normalization 
$$
\tilde{t} = \frac{t - \mu_t}{\sigma_t}
$$
"]
    QNORM["Position Normalization 
$$
\tilde{q} = \frac{q - \mu_q}{\sigma_q}
$$
"]
end

QTICK --> TICK2R
JCFG --> TICK2R
TICK2R --> QRAD["
$$
q(t)
$$
 Joint Positions in radians"]
TSEC --> TNORM
QRAD --> QNORM

subgraph S3[STAGE 3 - Measured Torque Ground Truth]
    LFRAC["Load Fraction 
$$
f = \frac{load_{raw}}{1000}
$$
"]
    VSCALE["Voltage Scale 
$$
V_s = \min\left(\frac{V_{act}}{12}, 1\right)
$$
"]
    TCONV["Torque 
$$
\tau = f \cdot 30 \cdot V_s \cdot 0.0981
$$
"]
    DIRFIX["Direction 
$$
\tau_{meas} = \tau \cdot d_j
$$
"]
end

LREG --> LFRAC
VREG --> VSCALE
LFRAC --> TCONV
VSCALE --> TCONV
TCONV --> DIRFIX
JCFG --> DIRFIX
DIRFIX --> TAUMEAS["
$$
\tau_{measured}
$$
 Ground Truth Torque in Nm"]

subgraph S4[STAGE 4 - Trajectory Neural Network]
    FF["Fourier Features 
$$
\varphi(\tilde{t}) = [\sin(B\tilde{t}), \cos(B\tilde{t})]
$$
"]
    L1[Linear 256 then SoftPlus]
    L2[Linear 256 then SoftPlus]
    L3[Linear 256 then SoftPlus]
    L4[Linear 256 then SoftPlus]
    LOUT["Linear to 
$$
n_j
$$
 outputs no activation"]
    FF --> L1 --> L2 --> L3 --> L4 --> LOUT
end

TNORM --> FF
LOUT --> QHAT["
$$
\hat{q}(t)
$$
 Predicted Smooth Position"]

subgraph S5[STAGE 5 - Autodifferentiation Engine]
    AD1["1st Autodiff 
$$
\frac{d\tilde{q}}{d\tilde{t}} = \nabla_{\tilde{t}} \hat{q}
$$
"]
    AD2["2nd Autodiff 
$$
\frac{d^2 \tilde{q}}{d\tilde{t}^2} = \nabla_{\tilde{t}} \frac{d\tilde{q}}{d\tilde{t}}
$$
"]
    RV["Rescale Velocity 
$$
\dot{q} = \frac{d\tilde{q}}{d\tilde{t}} \cdot \frac{\sigma_q}{\sigma_t}
$$
"]
    RA["Rescale Acceleration 
$$
\ddot{q} = \frac{d^2\tilde{q}}{d\tilde{t}^2} \cdot \frac{\sigma_q}{\sigma_t^2}
$$
"]
end

QHAT --> AD1
AD1 --> AD2
AD1 --> RV
AD2 --> RA
RV --> QDOT["
$$
\dot{q}(t)
$$
 Joint Velocity rad per s"]
RA --> QDDOT["
$$
\ddot{q}(t)
$$
 Joint Acceleration rad per s2"]

subgraph S6[STAGE 6 - Learnable Dynamics Sub-Networks]
    INN["InertiaNN 
$$
q \rightarrow L(q)
$$
 lower triangular"]
    CHOL["Cholesky 
$$
M(q) = L(q) L(q)^T + \varepsilon I
$$
"]
    CNN2["CoriolisNN 
$$
(q, \dot{q}) \rightarrow C(q,\dot{q})\dot{q}
$$
"]
    GNN2["GravityNN 
$$
q \rightarrow G(q)
$$
"]
    FNN2["FrictionNN 
$$
\dot{q} \rightarrow F(\dot{q})
$$
"]
    INN --> CHOL
end

QHAT --> INN
QHAT --> CNN2
QDOT --> CNN2
QHAT --> GNN2
QDOT --> FNN2

CHOL --> MQ["
$$
M(q)
$$
 6x6 Inertia Matrix"]
CNN2 --> CQ["
$$
C(q,\dot{q})\dot{q}
$$
 Coriolis Vector"]
GNN2 --> GQ["
$$
G(q)
$$
 Gravity Vector"]
FNN2 --> FQ["
$$
F(\dot{q})
$$
 Friction Vector"]

subgraph S7[STAGE 7 - Euler-Lagrange Dynamics]
    MATMUL["Inertial Term 
$$
M(q) \cdot \ddot{q}
$$
"]
    SUMALL["
$$
\hat{\tau} = M(q)\ddot{q} + C(q,\dot{q})\dot{q} + G(q) + F(\dot{q})
$$
"]
end

MQ --> MATMUL
QDDOT --> MATMUL
MATMUL --> SUMALL
CQ --> SUMALL
GQ --> SUMALL
FQ --> SUMALL
SUMALL --> TAUPRED["
$$
\hat{\tau}
$$
 Predicted Torque in Nm"]

subgraph S8[STAGE 8 - Multi Objective Loss]
    LPOS["
$$
\mathcal{L}_{pos} = \mathrm{MSE}(\hat{q}, q)
$$
"]
    LPHYS["
$$
\mathcal{L}_{phys} = \mathrm{MSE}(\hat{\tau}, \tau_{meas})
$$
"]
    LSMOOTH["
$$
\mathcal{L}_{smooth} = \frac{1}{N}\sum \lVert \ddot{q} \rVert^2
$$
"]
    LJERK["
$$
\mathcal{L}_{jerk} = \frac{1}{N}\sum \lVert q^{(3)} \rVert^2
$$
"]
    LSPD["
$$
\mathcal{L}_{spd} = \sum \max(0, -\lambda_{\min}(M))
$$
"]
    LTOTAL["
$$
\mathcal{L}_{total} = \mathcal{L}_{pos} + \alpha \mathcal{L}_{phys} + \beta \mathcal{L}_{smooth} + \gamma \mathcal{L}_{jerk} + \delta \mathcal{L}_{spd}
$$
"]
end

QHAT --> LPOS
QRAD --> LPOS
TAUPRED --> LPHYS
TAUMEAS --> LPHYS
QDDOT --> LSMOOTH
MQ --> LSPD
LPOS --> LTOTAL
LPHYS --> LTOTAL
LSMOOTH --> LTOTAL
LJERK --> LTOTAL
LSPD --> LTOTAL

subgraph S9[STAGE 9 - Backpropagation and Optimization]
    OPT[Adam Optimizer with CosineAnnealing LR]
    ES[Early Stopping patience 200 epochs]
end

LTOTAL --> OPT
OPT -.-> L1
OPT -.-> INN
OPT -.-> CNN2
OPT -.-> GNN2
OPT -.-> FNN2
OPT --> ES

subgraph S10[STAGE 10 - Output and Evaluation]
    TCOMP[Torque Comparison per joint]
    METRICS[RMSE MAE Correlation Bias]
    VIZPLOT[Visualization Dashboard]
    DYNOUT[Learned Dynamics Parameters]
    QSMOOTH[Smooth Kinematics Output]
end

TAUPRED --> TCOMP
TAUMEAS --> TCOMP
TCOMP --> METRICS
TCOMP --> VIZPLOT
MQ --> DYNOUT
GQ --> DYNOUT
FQ --> DYNOUT
QHAT --> QSMOOTH
QDOT --> QSMOOTH
QDDOT --> QSMOOTH
