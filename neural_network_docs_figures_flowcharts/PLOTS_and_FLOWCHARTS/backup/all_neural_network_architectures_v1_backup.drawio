        </mxCell>
        <mxCell id="pr_ref" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontFamily=Helvetica;fontStyle=2;" value="τ&lt;sub&gt;ref&lt;/sub&gt; = reduce_physics_to_total(φ̃) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt; &amp;nbsp;&amp;nbsp; [Theorem 1: sum ≈ τ̃* in noise-free case]" vertex="1">
          <mxGeometry height="36" width="665" x="20" y="586" as="geometry" />
        </mxCell>
        <mxCell id="pr_loss" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Training Loss (Additive Tikhonov — NOT a convex blend)&lt;/b&gt;&lt;br&gt;ℒ&lt;sub&gt;PR&lt;/sub&gt;(θ; e) = ℒ&lt;sub&gt;data&lt;/sub&gt; + α&lt;sub&gt;eff&lt;/sub&gt;(e) · ℒ&lt;sub&gt;phys&lt;/sub&gt;&lt;br&gt;α&lt;sub&gt;eff&lt;/sub&gt;(e) = λ · min(1, e/e&lt;sub&gt;w&lt;/sub&gt;) &amp;nbsp; [linear warm-up, γ = 0.05, e&lt;sub&gt;w&lt;/sub&gt; = 5% epochs]&lt;br&gt;ℒ&lt;sub&gt;phys&lt;/sub&gt; = MSE(τ̂, τ&lt;sub&gt;ref&lt;/sub&gt;) &amp;nbsp;— pulls prediction toward RNEA surface&lt;br&gt;Sweep: λ ∈ {0.05, 0.10, 0.20, 0.50, 1.0, 2.0}" vertex="1">
          <mxGeometry height="140" width="665" x="20" y="634" as="geometry" />
        </mxCell>
        <mxCell id="pr_sweep" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Hyperparameter sweep:&lt;/b&gt; 72 runs (6 fracs × 6 λ × 2 seeds)&lt;br&gt;Data fracs f ∈ {1.0, 0.5, 0.25, 0.10, 0.05, 0.02}" vertex="1">
          <mxGeometry height="62" width="665" x="20" y="794" as="geometry" />
        </mxCell>
        <mxCell id="pr_res" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=Helvetica;fontStyle=1;" value="&lt;b&gt;Best pooled test RMSE: &amp;nbsp;0.0980 N·m&lt;/b&gt; &amp;nbsp;(R² = 0.908)&lt;br&gt;Optimal at f = 0.05 (~3,300 samples) | λ = 0.5 &amp;nbsp;|&amp;nbsp; &gt;20× sample-efficiency advantage" vertex="1">
          <mxGeometry height="66" width="665" x="20" y="876" as="geometry" />
        </mxCell>
        <mxCell id="pr_inf" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;fontSize=11;fontFamily=Helvetica;fontStyle=2;" value="&lt;b&gt;Inference:&lt;/b&gt; requires RNEA call (4× pin.rnea per timestep)&lt;br&gt;Unbounded output — no hard worst-case guarantee" vertex="1">
          <mxGeometry height="50" width="665" x="20" y="952" as="geometry" />
