        <mxCell id="rc_tanh" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Tanh-bounded correction (Lemma 2):&lt;/b&gt;&lt;br&gt;δ = c&lt;sub&gt;s&lt;/sub&gt; · tanh( gθ(ũ) ) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt;&lt;br&gt;c&lt;sub&gt;s&lt;/sub&gt; = 0.5 &amp;nbsp;(non-learnable buffer) &amp;nbsp;|&amp;nbsp; ∥δ∥∞ &lt; c&lt;sub&gt;s&lt;/sub&gt; &amp;nbsp;unconditionally&lt;br&gt;Soft saturation: gradient → 0 when |gθ| ≫ 3" vertex="1">
          <mxGeometry height="100" width="665" x="20" y="482" as="geometry" />
        </mxCell>
        <mxCell id="rc_base" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontFamily=Helvetica;fontStyle=2;" value="τ̃&lt;sub&gt;phys&lt;/sub&gt; = reduce_physics_to_total(φ̃) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt; &amp;nbsp;&amp;nbsp; [epoch-0 prediction = RNEA, since tanh(0)=0]" vertex="1">
          <mxGeometry height="36" width="665" x="20" y="592" as="geometry" />
        </mxCell>
        <mxCell id="rc_fwd" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontFamily=Helvetica;fontStyle=1;" value="&lt;b&gt;Forward map (hard structural prior):&lt;/b&gt;&lt;br&gt;τ̂ = τ̃&lt;sub&gt;phys&lt;/sub&gt; + c&lt;sub&gt;s&lt;/sub&gt; · tanh( gθ(ũ) ) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt;&lt;br&gt;Network learns &lt;i&gt;only the residual gap&lt;/i&gt; — starts from physics-consistent prediction" vertex="1">
          <mxGeometry height="90" width="665" x="20" y="638" as="geometry" />
        </mxCell>
        <mxCell id="rc_loss" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Training Loss (Correction Regularisation)&lt;/b&gt;&lt;br&gt;ℒ&lt;sub&gt;RC&lt;/sub&gt;(θ; α&lt;sub&gt;r&lt;/sub&gt;) = ℒ&lt;sub&gt;data&lt;/sub&gt; + α&lt;sub&gt;r&lt;/sub&gt; · (1/NJ) ∑&lt;sub&gt;i,j&lt;/sub&gt; δ&lt;sub&gt;j&lt;/sub&gt;²&lt;br&gt;Penalises post-tanh correction δ — strongest pressure in linear region |gθ| &lt; 1&lt;br&gt;Gradient vanishes when δ = 0 (no penalty) AND when |δ| → c&lt;sub&gt;s&lt;/sub&gt; (saturated)&lt;br&gt;Sweep: α&lt;sub&gt;r&lt;/sub&gt; ∈ {0.005, 0.010, 0.050, 0.100, 0.500}" vertex="1">
          <mxGeometry height="140" width="665" x="20" y="748" as="geometry" />
        </mxCell>
        <mxCell id="rc_sweep" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Hyperparameter sweep:&lt;/b&gt; 60 runs (6 fracs × 5 α&lt;sub&gt;r&lt;/sub&gt; × 2 seeds)&lt;br&gt;Data fracs f ∈ {1.0, 0.5, 0.25, 0.10, 0.05, 0.02}" vertex="1">
          <mxGeometry height="62" width="665" x="20" y="908" as="geometry" />
        </mxCell>
        <mxCell id="rc_res" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=Helvetica;fontStyle=1;" value="&lt;b&gt;Best pooled test RMSE: &amp;nbsp;0.0967 N·m&lt;/b&gt; &amp;nbsp;(R² = 0.911)&lt;br&gt;Optimal at f = 0.05 (~3,300 samples) | α&lt;sub&gt;r&lt;/sub&gt; = 0.1 &amp;nbsp;|&amp;nbsp; Best of all three architectures" vertex="1">
          <mxGeometry height="66" width="665" x="20" y="980" as="geometry" />
        </mxCell>
        <mxCell id="rc_inf" parent="sw_rc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;fontSize=11;fontFamily=Helvetica;fontStyle=2;" value="&lt;b&gt;Inference:&lt;/b&gt; requires RNEA call (4× pin.rnea per timestep)&lt;br&gt;Hard bound: ∥τ̂ − τ̃&lt;sub&gt;phys&lt;/sub&gt;∥∞ &lt; c&lt;sub&gt;s&lt;/sub&gt; = 0.5 &amp;nbsp;(in normalised units)" vertex="1">
          <mxGeometry height="50" width="665" x="20" y="1056" as="geometry" />
        </mxCell>
        <mxCell id="rc_table" parent="sw_rc" style="text;html=1;strokeColor=#aaaaaa;fillColor=#fafafa;align=left;verticalAlign=top;spacingLeft=4;fontSize=11;fontFamily=Helvetica;" value="&lt;table style=&#39;border-collapse:collapse;width:100%;font-size:11px;font-family:Helvetica;&#39;&gt;&lt;tr style=&#39;background:#e8e8e8;&#39;&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;&lt;b&gt;Aspect&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;&lt;b&gt;ResCorr-FNN&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Input dim&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;7J = 35&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Physics at training&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Input + output base + loss reg&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Physics constraint&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;&lt;b&gt;Hard (architectural bound)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Tunable HP&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;α&lt;sub&gt;r&lt;/sub&gt; &amp;nbsp;(c&lt;sub&gt;s&lt;/sub&gt;=0.5 fixed)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Worst-case bound&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;∥τ̂ − τ̃&lt;sub&gt;phys&lt;/sub&gt;∥∞ &lt; 0.5&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="148" width="665" x="20" y="1116" as="geometry" />
        </mxCell>
