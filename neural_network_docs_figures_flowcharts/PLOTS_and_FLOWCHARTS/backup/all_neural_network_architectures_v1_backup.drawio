        <mxCell id="bb_fwd" parent="sw_bb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Forward map:&lt;/b&gt; &amp;nbsp; τ̂ = fθ( x̃&lt;sub&gt;k&lt;/sub&gt; ) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt;&lt;br&gt;fθ : ℝ&lt;sup&gt;15&lt;/sup&gt; → ℝ&lt;sup&gt;5&lt;/sup&gt; &amp;nbsp;|&amp;nbsp; Xavier-normal init &amp;nbsp;|&amp;nbsp; 69,637 params" vertex="1">
          <mxGeometry height="66" width="620" x="20" y="456" as="geometry" />
        </mxCell>
        <mxCell id="bb_loss" parent="sw_bb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Training Loss&lt;/b&gt;&lt;br&gt;ℒ&lt;sub&gt;BB&lt;/sub&gt;(θ) = (1/N) ∑&lt;sub&gt;i,j&lt;/sub&gt; w&lt;sub&gt;j&lt;/sub&gt; ( τ̂&lt;sub&gt;j&lt;/sub&gt; − τ̃*&lt;sub&gt;j&lt;/sub&gt; )²&lt;br&gt;Joint weights: w = [1.0, &lt;b&gt;2.5&lt;/b&gt;, 1.0, 1.0, 1.0] &amp;nbsp;(J2 up-weighted for heavy-tailed dist.)&lt;br&gt;Gradient: data-only, no physics term" vertex="1">
          <mxGeometry height="116" width="620" x="20" y="542" as="geometry" />
        </mxCell>
        <mxCell id="bb_sweep" parent="sw_bb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Hyperparameter sweep:&lt;/b&gt; 12 runs (6 data fracs × 2 seeds)&lt;br&gt;Data fracs f ∈ {1.0, 0.5, 0.25, 0.10, 0.05, 0.02}" vertex="1">
          <mxGeometry height="66" width="620" x="20" y="678" as="geometry" />
