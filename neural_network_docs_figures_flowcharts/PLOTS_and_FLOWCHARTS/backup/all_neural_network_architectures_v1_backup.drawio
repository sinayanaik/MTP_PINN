        <mxCell id="pr_table" parent="sw_pr" style="text;html=1;strokeColor=#aaaaaa;fillColor=#fafafa;align=left;verticalAlign=top;spacingLeft=4;fontSize=11;fontFamily=Helvetica;" value="&lt;table style=&#39;border-collapse:collapse;width:100%;font-size:11px;font-family:Helvetica;&#39;&gt;&lt;tr style=&#39;background:#e8e8e8;&#39;&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;&lt;b&gt;Aspect&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;&lt;b&gt;PhysReg-FNN&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Input dim&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;7J = 35&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Physics at training&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Input feature + loss term&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Physics constraint&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Soft (loss penalty)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Tunable HP&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;λ (physics weight)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Worst-case bound&lt;/td&gt;&lt;td style=&#39;padding:4px;border:1px solid #aaa;&#39;&gt;Unbounded&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
