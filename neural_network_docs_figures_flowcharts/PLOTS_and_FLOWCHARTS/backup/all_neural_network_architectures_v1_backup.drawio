        <mxCell id="pr_fwd" parent="sw_pr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontFamily=Helvetica;" value="&lt;b&gt;Forward map:&lt;/b&gt; &amp;nbsp; τ̂ = fθ( ũ ) ∈ ℝ&lt;sup&gt;5&lt;/sup&gt;&lt;br&gt;fθ : ℝ&lt;sup&gt;35&lt;/sup&gt; → ℝ&lt;sup&gt;5&lt;/sup&gt; &amp;nbsp;|&amp;nbsp; Xavier-normal init &amp;nbsp;|&amp;nbsp; 72,197 params" vertex="1">
